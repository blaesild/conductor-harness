{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": ".claude/hooks/session-start.sh"
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": ".claude/hooks/stop.sh",
        "timeout": 30
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(<PKG_MANAGER> *)",
      "Bash(npx *)",
      "Bash(tsc *)"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git push -f *)"
    ]
  }
}

Note: install.sh substitutes <PKG_MANAGER> with the detected package manager before writing settings.json.
